generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Producto {
  id        String          @id @default(cuid())
  nombre    String
  precio    Float
  stock     StockLote[]
  compras   CompraLinea[]
  traslados TrasladoLinea[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Factura {
  id             String         @id @default(cuid())
  numero         Int            @unique
  fecha          String
  clienteId      String?
  cliente        Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteNombre  String
  subtotal       Float
  saldoAnterior  Float          @default(0)
  totalGeneral   Float
  totalPagado    Float
  saldoPendiente Float
  cajaDeuda      Int            @default(0)
  cajaDejo       Int            @default(0)
  cajaRetiro     Int            @default(0)
  cajaNuevoSaldo Int            @default(0)
  observaciones  String         @default("")
  anulada        Boolean        @default(false)
  anuladaAt      DateTime?
  lineas         LineaFactura[]
  pagos          PagoFactura[]
  createdAt      DateTime       @default(now())
}

model LineaFactura {
  id        String  @id @default(cuid())
  facturaId String
  factura   Factura @relation(fields: [facturaId], references: [id])
  nombre    String
  qty       Int
  precio    Float
  subtotal  Float
}

model PagoFactura {
  id        String  @id @default(cuid())
  facturaId String
  factura   Factura @relation(fields: [facturaId], references: [id])
  tipo      String
  detalle   String  @default("")
  monto     Float
}

model Config {
  id                     String @id @default("singleton")
  ultimoNumeroFactura    Int    @default(0)
  ultimoNumeroMovimiento Int    @default(0)
}

model Cliente {
  id        String    @id @default(cuid())
  nombre    String
  telefono  String?
  direccion String?
  notas     String?
  activo    Boolean   @default(true)
  facturas  Factura[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Almacen {
  id               String      @id @default(cuid())
  nombre           String
  tipo             AlmacenTipo
  stock            StockLote[]
  trasladosOrigen  Traslado[]  @relation("AlmacenOrigen")
  trasladosDestino Traslado[]  @relation("AlmacenDestino")
  createdAt        DateTime    @default(now())
}

enum AlmacenTipo {
  CENTRAL
  MOVIL
  EXTERNO
}

model Compra {
  id            String        @id @default(cuid())
  fecha         String
  proveedor     String        @default("")
  observaciones String        @default("")
  lineas        CompraLinea[]
  createdAt     DateTime      @default(now())
}

model CompraLinea {
  id               String   @id @default(cuid())
  compra           Compra   @relation(fields: [compraId], references: [id])
  compraId         String
  producto         Producto @relation(fields: [productoId], references: [id])
  productoId       String
  cantidadTotal    Int
  cantidadRetirada Int      @default(0)
  precioCosto      Float
}

model StockLote {
  id          String   @id @default(cuid())
  almacen     Almacen  @relation(fields: [almacenId], references: [id])
  almacenId   String
  producto    Producto @relation(fields: [productoId], references: [id])
  productoId  String
  cantidad    Int
  precioCosto Float
  createdAt   DateTime @default(now())
}

model Traslado {
  id               String          @id @default(cuid())
  numeroMovimiento Int             @unique
  origen           Almacen         @relation("AlmacenOrigen", fields: [origenId], references: [id])
  origenId         String
  destino          Almacen         @relation("AlmacenDestino", fields: [destinoId], references: [id])
  destinoId        String
  fecha            String
  observaciones    String          @default("")
  lineas           TrasladoLinea[]
  createdAt        DateTime        @default(now())
}

model TrasladoLinea {
  id          String   @id @default(cuid())
  traslado    Traslado @relation(fields: [trasladoId], references: [id])
  trasladoId  String
  producto    Producto @relation(fields: [productoId], references: [id])
  productoId  String
  cantidad    Int
  precioCosto Float
}